<?xml version="1.0" encoding="utf-8"?>
<!-- FileProvider paths for Rivendell. Exposes the AI concept-image cache
     (filesDir/ai_images/) so AnkiDroid can import a cached image into its media
     collection via addMediaFromUri (FR-1.3.4, T4.4). Least-privilege: only the
     ai_images subtree is shareable, and only when code explicitly mints a URI. -->
<paths>
    <files-path
        name="ai_images"
        path="ai_images/" />
</paths>
